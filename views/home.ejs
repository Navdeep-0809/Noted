<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Noted - Your Collaborative Workspace</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="flex-center">
  <div class="glass-card" style="max-width: 600px; text-align: center; padding: 4rem 2rem;">
    <h1 class="gradient-text" style="font-size: 4rem; margin-bottom: 0.5rem; letter-spacing: -2px;">Noted</h1>
    <p class="text-muted" style="font-size: 1.25rem; margin-bottom: 3rem; font-weight: 500;">
      The seamless way to capture ideas and collaborate in real-time.
    </p>
    
    <div style="display: flex; gap: 1.5rem; justify-content: center;">
      <a href="/login" class="btn btn-outline" style="min-width: 140px;">Login</a>
      <a href="/register" class="btn btn-primary" style="min-width: 140px;">Get Started</a>
    </div>

    <div style="margin-top: 4rem; display: flex; justify-content: center; gap: 2rem;" class="text-muted">
      <div style="display: flex; align-items: center; gap: 0.5rem;">
        <span style="color: var(--success);">✦</span> Fast
      </div>
      <div style="display: flex; align-items: center; gap: 0.5rem;">
        <span style="color: var(--accent-secondary);">✦</span> Secure
      </div>
      <div style="display: flex; align-items: center; gap: 0.5rem;">
        <span style="color: var(--accent-primary);">✦</span> Real-time
      </div>
    </div>
  </div>
</body>
</html>
